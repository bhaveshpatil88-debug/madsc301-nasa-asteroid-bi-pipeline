          "rawSql": "SELECT\n  a.size_category AS \"Size Category\",\n  ROUND(AVG(ca.risk_score)::numeric, 1) AS \"Avg Risk Score\"\nFROM close_approaches ca\nJOIN asteroids a ON ca.asteroid_id = a.asteroid_id\nWHERE a.size_category IS NOT NULL\nGROUP BY a.size_category\nORDER BY AVG(ca.risk_score) DESC;",
