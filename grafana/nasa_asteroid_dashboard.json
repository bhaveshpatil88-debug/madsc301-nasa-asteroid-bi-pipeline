          "format": "table",
          "rawSql": "SELECT\n  size_category AS \"Size Category\",\n  COUNT(*) FILTER (WHERE is_potentially_hazardous = false) AS \"Non-Hazardous\",\n  COUNT(*) FILTER (WHERE is_potentially_hazardous = true) AS \"Hazardous\"\nFROM asteroids\nWHERE size_category IS NOT NULL\nGROUP BY size_category\nORDER BY\n  CASE size_category\n    WHEN 'Micro (<50m)' THEN 1\n    WHEN 'Small (50–140m)' THEN 2\n    WHEN 'Medium (140–500m)' THEN 3\n    WHEN 'Large (500m–1km)' THEN 4\n    WHEN 'Giant (>1km)' THEN 5\n    ELSE 6\n  END;",
